# ---- Database (Supabase Postgres) ----
# Get this from: Supabase Project > Settings > Database > ORM > Prisma 
# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://postgres.[YOUR-DB-URL]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://postgres.[YOUR-DB-URL]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ---- JWT ----
# Generate strong secrets locally, e.g.: openssl rand -base64 48
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ---- Server ----
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# ---- Currentcy exchange rate API ----
FX_API_BASE_URL="https://api.exchangerate.host"